# Backend target used by Next.js rewrites.
BACKEND_URL=http://localhost:8000

# Leave empty to use same-origin `/api/*` routes via rewrites.
NEXT_PUBLIC_API_BASE=

# Backward-compatible local option for rewrites if you already use it.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to true only when you want the UI to fall back to bundled mock data.
NEXT_PUBLIC_USE_MOCK=false
