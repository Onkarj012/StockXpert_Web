# Optional runtime tuning.
STOCKXPERT_DEFAULT_HORIZON=1
STOCKXPERT_DEFAULT_TOP_N=10
STOCKXPERT_MARKET_TTL=300
STOCKXPERT_OFF_MARKET_TTL=3600
STOCKXPERT_MARKET_INDEX=^NSEI
STOCKXPERT_MARKET_TIMEZONE=Asia/Kolkata
STOCKXPERT_SNAPSHOT_BACKEND=local
STOCKXPERT_FALLBACK_TO_LIVE_WHEN_SNAPSHOT_MISSING=true

# Optional: enable only if the browser calls the backend domain directly.
STOCKXPERT_CORS_ORIGINS=http://localhost:3000

# Local snapshot storage only. Keep this for development.
# STOCKXPERT_RECOMMENDATIONS_SNAPSHOT_DIR=backend/artifacts/cache

# R2 snapshot storage for production.
# STOCKXPERT_SNAPSHOT_BACKEND=r2
# STOCKXPERT_R2_BUCKET=stockxpert-snapshots
# STOCKXPERT_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STOCKXPERT_R2_ACCESS_KEY_ID=<access-key-id>
# STOCKXPERT_R2_SECRET_ACCESS_KEY=<secret-access-key>
# STOCKXPERT_R2_REGION=auto
# STOCKXPERT_R2_PREFIX=recommendations/daily

# Optional local scheduler. Railway cron should own snapshot generation in production.
# STOCKXPERT_SNAPSHOT_SCHEDULE_ENABLED=true
# STOCKXPERT_SNAPSHOT_SCHEDULE_HOUR=8
# STOCKXPERT_SNAPSHOT_SCHEDULE_MINUTE=0

# Optional: override bundled assets/inputs.
# STOCKXPERT_MANIFEST_PATH=artifacts/model_manifest.json
# STOCKXPERT_BUNDLE_DIR=artifacts/default_bundle
# STOCKXPERT_SENTIMENT_CSV=/absolute/path/to/sentiment.csv
